DirectoryIndex login.php

# Límites generales (soportar 600MB + 1GB)
php_value upload_max_filesize 1100M
php_value post_max_size 1700M

# Tiempos
php_value max_execution_time 3600
php_value max_input_time 3600

# Memoria
php_value memory_limit 2048M

# Múltiples archivos
php_value max_file_uploads 50
php_value max_input_vars 5000

# Bloquear acceso directo a archivos sensibles
<FilesMatch "^(config\.php|conexion\.php)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Headers de seguridad

# Evita que el navegador adivine el tipo de archivo
Header always set X-Content-Type-Options "nosniff" 

# Evita que el sitio sea embebido en un iframe de otro sitio
Header always set X-Frame-Options "SAMEORIGIN"

# Activa el filtro XSS del navegador
Header always set X-XSS-Protection "1; mode=block"

# Enmascaramiento de URLs - ocultar .php
RewriteEngine On

# Si alguien escribe /pagina.php, redirigir a /pagina
RewriteCond %{THE_REQUEST} /([^.]+)\.php [NC]
RewriteRule ^ /%1 [R=301,L]

# Internamente servir el .php sin que el usuario lo vea
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^.]+)$ $1.php [NC,L]